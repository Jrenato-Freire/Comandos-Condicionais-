Algoritmo "PREÇO MAÇAS"

Var
   Quantidade : Inteiro
   Total : Real


Inicio

      Escreva (" Digite a quantidade de maças :")
      Leia (Quantidade)
      
 Se Quantidade < 12 entao
    Total <- Quantidade * 1.30
    Senao
    Total <- Quantidade * 1.00

Fimse

     EscrevaL (" O total da compra : R$" , Total )


Fimalgoritmo